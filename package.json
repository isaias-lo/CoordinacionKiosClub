{
  "name": "despacho-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "copy-pdf-worker": "node -e \"const fs=require('fs');fs.mkdirSync('public',{recursive:true});fs.copyFileSync('node_modules/pdfjs-dist/build/pdf.worker.min.mjs','public/pdf.worker.min.mjs');fs.copyFileSync('node_modules/pdfjs-dist/build/pdf.min.mjs','public/pdf.min.mjs');\"",
    "prebuild": "npm run copy-pdf-worker",
    "predev": "npm run copy-pdf-worker",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "pdfjs-dist": "^5.6.205",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2"
  }
}
